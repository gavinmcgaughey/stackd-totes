# ---- Supabase (free) ----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Email notifications (Resend, free) ----
# resend.com → API Keys
RESEND_API_KEY=your-resend-api-key
# Where new-order alerts are sent (comma-separated for multiple recipients):
OWNER_EMAIL=you@example.com,partner@example.com
# Until you verify your own domain in Resend, leave this as-is:
EMAIL_FROM=Stack'd Totes <onboarding@resend.dev>

# ---- Stripe (online card payment) ----
# dashboard.stripe.com → Developers → API keys → Secret key
STRIPE_SECRET_KEY=your-stripe-secret-key
# Created when you add the webhook endpoint (see README):
STRIPE_WEBHOOK_SECRET=your-webhook-signing-secret
# Flip to "true" to switch the booking flow from pay-on-delivery to pay-now:
NEXT_PUBLIC_STRIPE_ENABLED=false

# ---- Admin dashboard ----
# The password you'll type to log in at /admin
ADMIN_PASSWORD=change-me-to-something-strong
# Any long random string used to sign the admin session cookie
ADMIN_SECRET=replace-with-a-long-random-string

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
